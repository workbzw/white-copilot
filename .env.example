LLM_BASE_URL=
# 模型：不填默认 deepseek-ai/DeepSeek-V3.2；可选 deepseek-ai/DeepSeek-R1-Distill-Qwen-32B 等
LLM_MODEL=
LLM_API_KEY=
# 仅在使用 R1/reasoner 类模型时生效：设为 1 或 true 可关闭思考模式，其它模型不受影响
# LLM_DISABLE_THINKING=1
# 正文生成系统人设（可选）：不设则使用默认大唐研究院研究员人设；设为多行文本时需在 .env 中整段填写
# LLM_SYSTEM_PERSONA=

# 知识库：仅在使用者于界面选择知识库时参与检索，无系统默认
KNOWLEDGE_API_KEY=
KNOWLEDGE_BASE_URL=http://192.168.93.128:11014
# 可选知识库列表从 GET {BASE_URL}/datasets 拉取（BASE_URL 需含 /v1 等前缀）；拉取失败时可改用静态配置（JSON 数组）：
# KNOWLEDGE_DATASETS_OPTIONS=[{"id":"id1","name":"报告库"}]
# 以下仅用于 /api/knowledge-retrieve-test 调试，正文生成不使用：
# KNOWLEDGE_DATASET_ID=
# KNOWLEDGE_DATASET_IDS=id1,id2